{
  "name": "EnigmaProject",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "tsc --noEmit && eslint .",
    "lint:fix": "tsc --noEmit && eslint --fix .",
    "start": "react-native start",
    "test": "jest",
    "test:e2e:smoke": "maestro test e2e/smoke/",
    "prettier": "prettier src/**/*.{ts,tsx}",
    "prettier:fix": "prettier --write src/**/*.{ts,tsx}",
    "format": "npm run prettier:fix && npm run lint:fix",
    "prepare": "husky",
    "postinstall": "node scripts/fix-drawer-assets.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native/gradle-plugin": "^0.84.1",
    "@react-native/new-app-screen": "^0.84.1",
    "@react-navigation/drawer": "7.9.4",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@reduxjs/toolkit": "^2.11.2",
    "react": "^19.2.3",
    "react-native": "0.84.1",
    "react-native-gesture-handler": "^2.10.1",
    "react-native-paper": "^5.8.0",
    "react-native-reanimated": "^4.2.2",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-worklets": "^0.7.4",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@eslint/js": "^9.39.3",
    "@react-native-community/cli": "^20.1.2",
    "@react-native-community/cli-platform-android": "^20.1.2",
    "@react-native-community/cli-platform-ios": "^20.1.2",
    "@react-native/babel-preset": "^0.84.1",
    "@react-native/metro-config": "^0.84.1",
    "@react-native/typescript-config": "^0.84.1",
    "@testing-library/react-native": "^14.0.0-beta.0",
    "@tsconfig/react-native": "^3",
    "@types/jest": "^29.2.1",
    "@types/react": "~19.2.3",
    "@types/react-test-renderer": "^19.0.1",
    "@types/redux-mock-store": "^1.0.3",
    "babel-jest": "^29.2.1",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-testing-library": "^7.16.0",
    "husky": "^9.1.7",
    "jest": "^29.6.3",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.2.3",
    "redux-mock-store": "^1.5.4",
    "ts-jest": "^29.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
